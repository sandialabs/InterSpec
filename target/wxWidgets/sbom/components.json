      "notes": "Vendored multidimensional numerical integration library.",
      "version_source": "vendored:external_libs/Cuba-3.0"
    },
    {
      "name": "muparserx",
      "version": "4.0.7",
      "type": "library",
      "license": "BSD-2-Clause",
