    {
      "name": "nlohmann-json",
      "version": "3.12.0",
      "type": "library",
      "license": "MIT",
      "url": "https://github.com/nlohmann/json",
      "notes": "Header-only JSON library, vendored via SpecUtils.",
      "version_source": "vendored:external_libs/SpecUtils/3rdparty/nlohmann"
    },
    {
      "name": "rapidxml",
      "version": "1.13",
      "type": "library",
      "license": "MIT",
      "url": "http://rapidxml.sourceforge.net/",
