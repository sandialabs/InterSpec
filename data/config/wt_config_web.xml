<!--
    InterSpec Wt configuration: production multi-user web deployment.

    Intended for the containerized/server builds (target/docker/*, the
    Linux dep_build, and any reverse-proxied public deployment).

    Derived from the Wt 4.12.6 example config. Sections appear in the
    same order as the upstream reference; only the comments specific to
    InterSpec choices have been added or rewritten. Defaults that match
    the Wt 4 reference are left explicit so that intent is clear when a
    deployer audits the file.

    Companion files:
      wt_config_desktop.xml - single-user native (macOS/Electron/wx/local dev)
      wt_config_mobile.xml  - iOS / Android in-app server
  -->
<server>

    <application-settings location="*">

        <session-management>
            <!-- Shared-process: one wt server process serving all sessions.
                 The wthttp connector ignores num-processes and always uses 1. -->
            <shared-process>
                <num-processes>1</num-processes>
            </shared-process>

            <!-- URL-based tracking: avoids CSRF/BREACH risks from cookie-based
                 session IDs, and lets concurrent InterSpec sessions coexist in
                 a single browser. -->
            <tracking>URL</tracking>

            <reload-is-new-session>true</reload-is-new-session>

            <!-- 10 min inactivity timeout; reverse proxy in front of this should
                 keep keepalives flowing for active users. -->
            <timeout>600</timeout>

            <!-- Quit a session after 15 min of zero user interaction, even if
                 the long-poll is still alive (mitigates abandoned-tab leaks). -->
            <idle-timeout>900</idle-timeout>

            <bootstrap-timeout>10</bootstrap-timeout>

            <!-- Server-push long-poll refresh interval (seconds). 50s is the Wt
                 default and works through every reverse proxy we have tested. -->
            <server-push-timeout>50</server-push-timeout>
        </session-management>

        <!-- FastCGI connector settings. InterSpec ships with the built-in
             wthttp connector, so these have no effect unless a deployment
             rebuilds against the FastCGI connector. -->
        <connector-fcgi>
            <valgrind-path></valgrind-path>
            <run-directory>/var/run/wt</run-directory>
        </connector-fcgi>

        <!-- ISAPI connector (MS IIS) - irrelevant to InterSpec's wthttp server,
             kept at default. -->
        <connector-isapi>
            <max-memory-request-size>128</max-memory-request-size>
        </connector-isapi>

        <debug>false</debug>
        <debug-level>framework</debug-level>

        <!-- Log to stderr; container orchestrators (Docker, systemd) capture it. -->
        <log-file></log-file>
        <log-config>* -debug</log-config>

        <!-- 64 MiB cap on POST bodies - large enough for typical spectrum file
             uploads, small enough to deter casual DoS. -->
        <max-request-size>65536</max-request-size>

        <max-formdata-size>5120</max-formdata-size>
        <max-pending-events>1000</max-pending-events>

        <!-- 12 worker threads: lets several concurrent users do peak fits and
             relative-activity calculations without blocking each other. -->
        <num-threads>12</num-threads>

        <session-id-length>16</session-id-length>

        <plain-ajax-sessions-ratio-limit>1</plain-ajax-sessions-ratio-limit>
        <sessions-threshold-for-dos-protection>100</sessions-threshold-for-dos-protection>
        <ajax-puzzle>false</ajax-puzzle>

        <strict-event-serialization>false</strict-event-serialization>

        <!-- Long-polling everywhere. The latency difference vs. WebSockets is
             invisible for spectrum analysis, and long-polling traverses every
             corporate proxy that may eat a wss:// upgrade. Also sidesteps a
             known Wt issue where implementStateless() emits unexpected JS
             under web-sockets. -->
        <web-sockets>false</web-sockets>

        <webgl-detection>true</webgl-detection>

        <redirect-message>Load basic HTML</redirect-message>

        <!-- Trusted-proxy config: which reverse-proxy headers Wt will honor for
             client-IP determination. By default (empty <trusted-proxies/>) all
             X-Forwarded-* headers are ignored.

             To enable when deployed behind nginx/Apache/Cloudflare/etc., set
             original-ip-header to the header your proxy emits and add the
             proxy's IP/CIDR to <trusted-proxies>. -->
        <trusted-proxy-config>
            <original-ip-header>X-Forwarded-For</original-ip-header>
            <trusted-proxies>
                <!-- Uncomment the entries that match your deployment. -->
                <!-- loopback -->
                <!--
                <proxy>127.0.0.1/8</proxy>
                <proxy>::1/128</proxy>
                -->
                <!-- private network -->
                <!--
                <proxy>10.0.0.0/8</proxy>
                <proxy>172.16.0.0/12</proxy>
                <proxy>192.168.0.0/16</proxy>
                <proxy>fc00::/7</proxy>
                -->
            </trusted-proxies>
        </trusted-proxy-config>

        <inline-css>true</inline-css>

        <indicator-timeout>500</indicator-timeout>
        <double-click-timeout>200</double-click-timeout>

        <user-agents type="ajax" mode="black-list">
        </user-agents>

        <!-- Bots are served plain HTML with no Ajax session. InterSpec is not
             search-indexable in any meaningful way, but the entries below avoid
             spinning up doomed Ajax sessions for known crawlers. -->
        <user-agents type="bot">
            <user-agent>.*Googlebot.*</user-agent>
            <user-agent>.*msnbot.*</user-agent>
            <user-agent>.*Slurp.*</user-agent>
            <user-agent>.*Crawler.*</user-agent>
            <user-agent>.*Bot.*</user-agent>
            <user-agent>.*ia_archiver.*</user-agent>
            <user-agent>.*Twiceler.*</user-agent>
            <user-agent>.*Yandex.*</user-agent>
            <user-agent>.*Nutch.*</user-agent>
            <user-agent>.*MJ12bot.*</user-agent>
            <user-agent>.*Baiduspider.*</user-agent>
            <user-agent>.*Ezooms.*</user-agent>
            <user-agent>.*Sogou web spider.*</user-agent>
            <user-agent>.*AhrefsBot.*</user-agent>
        </user-agents>

        <UA-Compatible></UA-Compatible>

        <progressive-bootstrap>false</progressive-bootstrap>
        <delay-load-at-boot>true</delay-load-at-boot>
        <session-id-cookie>false</session-id-cookie>
        <cookie-checks>true</cookie-checks>

        <!-- HTTP response headers added to every reply. HSTS is intentionally
             not set here - if you terminate TLS in front of InterSpec, set HSTS
             at the reverse proxy where the cert lives. -->
        <http-headers>
            <header name="X-Content-Type-Options" content="nosniff" />
            <header name="Referrer-Policy" content="strict-origin-when-cross-origin" />
        </http-headers>

        <x-frame-same-origin>true</x-frame-same-origin>

        <use-script-nonce>false</use-script-nonce>

        <serve-private-resources-to-bots>false</serve-private-resources-to-bots>
        <bot-resources-path>wt-temp</bot-resources-path>
        <max-auto-removable-public-resources>1000</max-auto-removable-public-resources>

        <allowed-origins>
        </allowed-origins>

        <properties>
            <!-- <property name="baseURL">https://mysite.example.com/interspec</property> -->

            <property name="resourcesURL">resources/</property>

            <property name="favicon">InterSpec_resources/favicon.ico</property>

            <!-- If using the InterSpec map tool from a self-hosted Leaflet,
                 point these at your CDN/mirror. -->
            <!-- <property name="leafletJSURL">https://unpkg.com/leaflet@1.5.1/dist/leaflet.js</property> -->
            <!-- <property name="leafletCSSURL">https://unpkg.com/leaflet@1.5.1/dist/leaflet.css</property> -->

            <!-- Set if WGoogleMap is used; consumed at runtime in
                 src/GoogleMap.cpp via WApplication::readConfigurationProperty. -->
            <!-- <property name="google_api_key"></property> -->
        </properties>

    </application-settings>

</server>
