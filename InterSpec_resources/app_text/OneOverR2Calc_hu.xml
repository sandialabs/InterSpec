  -->
  <message id="oor2c-instructions">Két különböző helyről végzett mérés alapján határozza meg a nem látható forrás távolságát. Pl. amikor a forrás fal mögött van.</message>
  <message id="oor2c-near-meas-label">Közeli mérés intenzitása:</message>
  <message id="oor2c-far-meas-label">Távoli mérés intenzitása:</message>
  <message id="oor2c-background-intensity">Háttérintenzitás (opcionális):</message>
  <message id="oor2c-dist-label">Mérések közötti távolság:</message>
  <message id="oor2c-power-law-label">Hatványtörvény</message>
  <message id="oor2c-low-scatter">Alacsony szórás vagy csúcsterület, 1/r^2</message>
  <message id="oor2c-mid-scatter">Közepes szórás dózisteljesítmény, 1/r^1.85</message>
  <message id="oor2c-high-scatter">Magas szórás dózisteljesítmény, 1/r^1.65</message>
  <message id="oor2c-dist-to-near-label">Közeli mérés távolsága a forrástól:</message>
